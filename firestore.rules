rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Users collection – authenticated users can read/write
    match /users/{userId} {
      allow read, write: if request.auth != null;
    }

    // Attendance – authenticated users can read/write
    match /attendance/{document=**} {
      allow read, write: if request.auth != null;
    }

    // Announcements –
    //   read:  any authenticated user
    //   write: only admin (role field on users doc must equal "admin")
    match /announcements/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin";
    }

    // FCM tokens –
    //   users can read/write only their own token document (keyed by uid)
    match /fcm_tokens/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
